#!/bin/bash

echo "wallpaper {" > ~/.config/hypr/hyprpaper.conf
echo "    monitor =" >> ~/.config/hypr/hyprpaper.conf
echo "    path = `realpath $1`" >> ~/.config/hypr/hyprpaper.conf
echo "}" >> ~/.config/hypr/hyprpaper.conf
echo "splash = false" >> ~/.config/hypr/hyprpaper.conf

killall hyprpaper
hyprpaper &
disown hyprpaper
