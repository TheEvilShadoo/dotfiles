#!/bin/sh

killall hypridle

# Sync up
doas emerge --sync --jobs `nproc`

# Exit on ctrl + c
trap exit SIGINT SIGTERM

# Check for updates requiring additional steps
eix -qu sys-apps/portage && export PORTAGE_UP=1
eix -qu sys-kernel/\*-sources && export KERN_UP=1 
eix -qu dev-lang/go && export GO_UP=1
eix -qu dev-lang/perl && export PERL_UP=1

if [ $PORTAGE_UP ]; then
    doas emerge -u1 sys-apps/portage

    # Exit on ctrl + c
    trap exit SIGINT SIGTERM
fi

# Update the world set
doas emerge -uND @world
EMERGE_STATUS=$?

# Check if we have pending configuration files
CONFIG_FILES_EXIST=$(find /etc -maxdepth 1 -name '._cfg' 2>/dev/null | wc -l)

# If emerge failed OR we have config files to merge
if [ $EMERGE_STATUS -ne 0 ] || [ $CONFIG_FILES_EXIST -gt 0 ]; then
    if [ $CONFIG_FILES_EXIST -gt 0 ]; then
        echo "Configuration file updates needed. Running dispatch-conf..."
        doas dispatch-conf

        # After handling configs, check if we need to resume the failed emerge
        if [ $EMERGE_STATUS -ne 0 ]; then
            echo "Resuming emerge after configuration file updates..."
            doas emerge -uND @world
            EMERGE_STATUS=$?
        fi
    else
        # Emerge failed but no config file - likely a different error
        echo "Emerge failed for other reasons than configuration files"
    fi
fi

# Only proceed with rebuilds if the main emerge was successful
if [ $EMERGE_STATUS -eq 0 ]; then
    if [ $KERN_UP ]; then
        doas emerge @module-rebuild
    fi

    if [ $GO_UP ]; then
        doas emerge @golang-rebuild
    fi

    if [ $PERL_UP ]; then
        doas perl-cleaner --all
    fi

    # Update live packages
    doas emerge @smart-live-rebuild

    # Clean orphaned dependencies
    doas emerge -c

    # Completion message
    cowsay Emerge complete! | lolcat
fi

hyprctl --quiet dispatch exec hypridle
